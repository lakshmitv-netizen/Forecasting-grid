{
  "name": "nov24_proto",
  "version": "1.0.0",
  "private": true,
  "main": "electron.js",
  "author": "Manufacturing Cloud",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "serve": "^14.2.5"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^24.13.3"
  },
  "scripts": {
    "start": "NODE_OPTIONS='--localstorage-file=/tmp/localstorage.json' react-scripts start",
    "build": "NODE_OPTIONS='--localstorage-file=/tmp/localstorage.json' react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "heroku-postbuild": "NODE_OPTIONS='--localstorage-file=/tmp/localstorage.json' npm run build",
    "serve": "serve -s build -l $PORT",
    "electron": "electron .",
    "electron-dev": "ELECTRON_IS_DEV=1 electron .",
    "electron-pack": "npm run build && electron-builder",
    "dist": "npm run build && electron-builder --mac",
    "dist-mac": "NODE_OPTIONS='--localstorage-file=/tmp/localstorage.json' npm run build && cp public/electron.js electron.js && cp public/preload.js preload.js && electron-builder --mac && rm electron.js preload.js",
    "package-mac": "NODE_OPTIONS='--localstorage-file=/tmp/localstorage.json' npm run build && electron-builder --mac --dir",
    "build-nov24-proto": "NODE_OPTIONS='--localstorage-file=/tmp/localstorage.json' npm run build && cp public/electron.js electron.js && cp public/preload.js preload.js && electron-builder --mac && rm electron.js preload.js"
  },
  "build": {
    "appId": "com.nov24proto.app",
    "productName": "nov24_proto",
    "extraMetadata": {
      "main": "electron.js"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "default",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSHighResolutionCapable": true
      }
    },
    "files": [
      "build/**/*",
      "electron.js",
      "preload.js",
      "package.json",
      "!node_modules/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "build",
        "to": "build",
        "filter": ["**/*"]
      }
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  }
}
